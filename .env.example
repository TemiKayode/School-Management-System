# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
SCHOOL_LOGO_URL=https://yourschool.com/logo.png

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://sms_user:sms_pass@localhost:5432/school_db?schema=public"
REDIS_URL="redis://localhost:6379"

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Encryption (AES-256-GCM for PII fields) ──────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY=your_64_hex_char_aes_key_here

# ─── OAuth 2.0 ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

MS_CLIENT_ID=your_microsoft_azure_app_client_id
MS_CLIENT_SECRET=your_microsoft_azure_app_client_secret
MS_TENANT_ID=common

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxx
EMAIL_FROM=noreply@yourschool.com

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ─── Payments ─────────────────────────────────────────────────────────────────
# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx

# PayPal (use 'sandbox' or 'production')
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxx

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourschool.com

# ─── Cloud Storage (AWS S3) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=xxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxx
AWS_S3_BUCKET=school-management-files
AWS_REGION=us-east-1

# ─── MFA ──────────────────────────────────────────────────────────────────────
MFA_ISSUER=SchoolManagementSystem

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://<key>@o<org>.ingest.us.sentry.io/<project>

# ─── Mobile / CORS ────────────────────────────────────────────────────────────
MOBILE_ORIGIN=exp://localhost:8081
